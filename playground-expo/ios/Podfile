# Set by expo-router. This enables Fabric-only features from react-native-screens
ENV['RNS_GAMMA_ENABLED'] ||= '1'
require File.join(File.dirname(`node --print "require.resolve('expo/package.json')"`), "scripts/autolinking")
require File.join(File.dirname(`node --print "require.resolve('react-native/package.json')"`), "scripts/react_native_pods")

require 'json'
podfile_properties = JSON.parse(File.read(File.join(__dir__, 'Podfile.properties.json'))) rescue {}

def ccache_enabled?(podfile_properties)
  # Environment variable takes precedence
  return ENV['USE_CCACHE'] == '1' if ENV['USE_CCACHE']

  # Fall back to Podfile properties
  podfile_properties['apple.ccacheEnabled'] == 'true'
end

# Patch Expo SDK 55 pods so they compile under Swift 6.2 / Xcode 26.
# The issues are isolated-conformance and Sendable errors that the upstream
# SDK does not hit in its own CI configuration.
def patch_expo_modules_for_swift62
  # expo-router: main-actor-isolated view classes need explicit isolated
  # conformances for protocols coming from other modules.
  expo_router_root = `node --print "require.resolve('expo-router/package.json')" 2>/dev/null`.strip
  if !expo_router_root.empty?
    expo_router_root = File.dirname(expo_router_root)
    files = [
      File.join(expo_router_root, 'ios/LinkPreview/LinkPreviewNativeActionView.swift'),
      File.join(expo_router_root, 'ios/LinkPreview/LinkPreviewNativeView.swift'),
      File.join(expo_router_root, 'ios/LinkPreview/LinkZoomTransition.swift'),
      File.join(expo_router_root, 'ios/Toolbar/RouterToolbarHostView.swift'),
    ]

    files.each do |path|
      next unless File.exist?(path)
      content = File.read(path)
      original = content.dup

      content.gsub!(
        /class NativeLinkPreviewView: RouterViewWithLogger, UIContextMenuInteractionDelegate,\n  RNSDismissibleModalProtocol, LinkPreviewMenuUpdatable \{/,
        "class NativeLinkPreviewView: RouterViewWithLogger, UIContextMenuInteractionDelegate,\n  @MainActor RNSDismissibleModalProtocol, @MainActor LinkPreviewMenuUpdatable {"
      )
      content.gsub!(/, LinkPreviewMenuUpdatable \{/, ', @MainActor LinkPreviewMenuUpdatable {')
      content.gsub!(/, LinkPreviewIndirectTriggerProtocol \{/, ', @MainActor LinkPreviewIndirectTriggerProtocol {')

      if content != original
        File.write(path, content)
        Pod::UI.puts "Patched isolated conformances in #{path}"
      end
    end
  end

  # expo-linking: the shared registry singleton is flagged as non-Sendable.
  expo_linking_root = `node --print "require.resolve('expo-linking/package.json')" 2>/dev/null`.strip
  if !expo_linking_root.empty?
    expo_linking_root = File.dirname(expo_linking_root)
    path = File.join(expo_linking_root, 'ios/ExpoLinkingRegistry.swift')
    if File.exist?(path)
      content = File.read(path)
      if !content.include?('@unchecked Sendable')
        content = content.sub(
          /class ExpoLinkingRegistry \{/,
          "final class ExpoLinkingRegistry: @unchecked Sendable {"
        )
        File.write(path, content)
        Pod::UI.puts "Patched Sendable conformance in #{path}"
      end
    end
  end

  # expo-font: global mutable state is manually synchronized but flagged as
  # non-concurrency-safe by Swift 6.
  expo_font_paths = Dir.glob(File.expand_path('../node_modules/.pnpm/expo-font@*/node_modules/expo-font/ios/FontFamilyAliasManager.swift', __dir__))
  expo_font_path = expo_font_paths.first
  if expo_font_path && File.exist?(expo_font_path)
    content = File.read(expo_font_path)
    original = content.dup
    content = content.sub(
      'private var fontFamilyAliases = [String: String]()',
      'private nonisolated(unsafe) var fontFamilyAliases = [String: String]()'
    )
    content = content.sub(
      'private var hasSwizzled = false',
      'private nonisolated(unsafe) var hasSwizzled = false'
    )
    if content != original
      File.write(expo_font_path, content)
      Pod::UI.puts "Patched global mutable state in #{expo_font_path}"
    end
  end

  # expo-file-system: FileSystemBackgroundSessionHandler needs explicit
  # @MainActor isolation for its AppDelegate subscriber conformance.
  expo_file_system_paths = Dir.glob(File.expand_path('../node_modules/.pnpm/expo-file-system@*/node_modules/expo-file-system/ios/Legacy/FileSystemBackgroundSessionHandler.swift', __dir__))
  expo_file_system_path = expo_file_system_paths.first
  if expo_file_system_path && File.exist?(expo_file_system_path)
    content = File.read(expo_file_system_path)
    if !content.include?('@MainActor')
      content = content.sub(
        'public final class FileSystemBackgroundSessionHandler: ExpoAppDelegateSubscriber, EXSessionHandlerProtocol {',
        "@MainActor\npublic final class FileSystemBackgroundSessionHandler: ExpoAppDelegateSubscriber, EXSessionHandlerProtocol {"
      )
      File.write(expo_file_system_path, content)
      Pod::UI.puts "Patched main-actor isolation in #{expo_file_system_path}"
    end
  end

  # expo-router: global mutable state in ExpoHeadModule is flagged as
  # non-concurrency-safe.
  if !expo_router_root.empty?
    path = File.join(expo_router_root, 'ios/ExpoHeadModule.swift')
    if File.exist?(path)
      content = File.read(path)
      if content.include?("var launchedActivity: NSUserActivity?") && !content.include?('nonisolated(unsafe) var launchedActivity')
        content = content.sub(
          "var launchedActivity: NSUserActivity?",
          "nonisolated(unsafe) var launchedActivity: NSUserActivity?"
        )
        File.write(path, content)
        Pod::UI.puts "Patched global mutable state in #{path}"
      end
    end

    # expo-router: LinkPreviewNativeNavigation operates entirely on UIKit/RNScreens
    # types and needs to be main-actor isolated under Swift 6.2.
    path = File.join(expo_router_root, 'ios/LinkPreview/LinkPreviewNativeNavigation.swift')
    if File.exist?(path)
      content = File.read(path)
      # Heal any previously-applied patch that used a literal backslash-n.
      content = content.gsub('@MainActor\\ninternal class LinkPreviewNativeNavigation {', "@MainActor\ninternal class LinkPreviewNativeNavigation {")
      if !content.include?("@MainActor\ninternal class LinkPreviewNativeNavigation {")
        content = content.sub(
          'internal class LinkPreviewNativeNavigation {',
          "@MainActor\ninternal class LinkPreviewNativeNavigation {"
        )
      end
      if content != File.read(path)
        File.write(path, content)
        Pod::UI.puts "Patched main-actor isolation in #{path}"
      end
    end

    # expo-router: RouterFontUtils operates on UIBarButtonItem and needs to be
    # main-actor isolated under Swift 6.2.
    path = File.join(expo_router_root, 'ios/Toolbar/RouterFontUtils.swift')
    if File.exist?(path)
      content = File.read(path)
      # Heal any previously-applied patch that used a literal backslash-n.
      content = content.gsub('@MainActor\\nstruct RouterFontUtils {', "@MainActor\nstruct RouterFontUtils {")
      if !content.include?("@MainActor\nstruct RouterFontUtils {")
        content = content.sub(
          'struct RouterFontUtils {',
          "@MainActor\nstruct RouterFontUtils {"
        )
      end
      if content != File.read(path)
        File.write(path, content)
        Pod::UI.puts "Patched main-actor isolation in #{path}"
      end
    end
  end
end

ENV['EX_DEV_CLIENT_NETWORK_INSPECTOR'] ||= podfile_properties['EX_DEV_CLIENT_NETWORK_INSPECTOR']
ENV['RCT_USE_RN_DEP'] ||= '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true'
ENV['RCT_USE_PREBUILT_RNCORE'] ||= '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true'
ENV['RCT_HERMES_V1_ENABLED'] ||= '1' if podfile_properties['expo.useHermesV1'] == 'true'
platform :ios, podfile_properties['ios.deploymentTarget'] || '15.1'

prepare_react_native_project!

target 'RNZipArchivePlayground' do
  use_expo_modules!

  if ENV['EXPO_USE_COMMUNITY_AUTOLINKING'] == '1'
    config_command = ['node', '-e', "process.argv=['', '', 'config'];require('@react-native-community/cli').run()"];
  else
    config_command = [
      'node',
      '--no-warnings',
      '--eval',
      'require(\'expo/bin/autolinking\')',
      'expo-modules-autolinking',
      'react-native-config',
      '--json',
      '--platform',
      'ios'
    ]
  end

  config = use_native_modules!(config_command)

  use_frameworks! :linkage => podfile_properties['ios.useFrameworks'].to_sym if podfile_properties['ios.useFrameworks']
  use_frameworks! :linkage => ENV['USE_FRAMEWORKS'].to_sym if ENV['USE_FRAMEWORKS']

  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => podfile_properties['expo.jsEngine'] == nil || podfile_properties['expo.jsEngine'] == 'hermes',
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :privacy_file_aggregation_enabled => podfile_properties['apple.privacyManifestAggregationEnabled'] != 'false',
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      :ccache_enabled => ccache_enabled?(podfile_properties),
    )

    # Xcode / Swift 6 workaround:
    # - Expo SDK 55 pods use Swift 6 and rely on inferred isolated conformances
    #   (Swift 6.2 / Xcode 26). That's why Expo iOS runs on macos-26.
    # - react-native-screens 4.25.x gamma sources are not Swift-6 clean, so
    #   keep that pod on Swift 5.
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        if target.name == 'RNScreens'
          config.build_settings['SWIFT_VERSION'] = '5.0'
          config.build_settings.delete('SWIFT_STRICT_CONCURRENCY')
          config.build_settings.delete('SWIFT_UPCOMING_FEATURES')
        else
          config.build_settings['SWIFT_VERSION'] = '6.0'
          config.build_settings['SWIFT_UPCOMING_FEATURES'] = 'InferIsolatedConformances'
        end
      end
    end

    installer.pods_project.save

    # Patch Expo SDK 55 sources for Swift 6.2 / Xcode 26 compatibility.
    patch_expo_modules_for_swift62

    # Also patch the generated xcconfigs so Xcode actually sees the settings.
    Dir.glob(File.join(installer.sandbox.target_support_files_root, '**', '*.xcconfig')).each do |xcconfig_path|
      target_name = File.basename(xcconfig_path, '.xcconfig').split('.').first
      if target_name == 'RNScreens'
        next if File.read(xcconfig_path).include?('SWIFT_VERSION = 5.0')
        File.open(xcconfig_path, 'a') do |file|
          file.puts ""
          file.puts "// Xcode / Swift 6 workaround"
          file.puts "SWIFT_VERSION = 5.0"
        end
      else
        next if File.read(xcconfig_path).include?('SWIFT_VERSION = 6.0')
        File.open(xcconfig_path, 'a') do |file|
          file.puts ""
          file.puts "// Xcode / Swift 6 workaround"
          file.puts "SWIFT_VERSION = 6.0"
          file.puts "SWIFT_UPCOMING_FEATURES = InferIsolatedConformances"
        end
      end
    end
  end
end
